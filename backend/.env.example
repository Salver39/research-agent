OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
OPENAI_MODEL_MINI=gpt-5.4
# Max parallel OpenAI requests (design agents use asyncio.gather). Raise on higher tiers.
OPENAI_MAX_CONCURRENCY=3
DATABASE_URL=sqlite+aiosqlite:///./research_agent.db
CHROMA_PERSIST_DIR=./chroma_db
# Отключает PostHog-телеметрию Chroma (она ломается с свежим posthog-python и шумит в логах)
ANONYMIZED_TELEMETRY=False
CORS_ORIGINS=http://localhost:3000
