# Copy this file to .env and fill in the values.
# docker-compose reads .env automatically.

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get an API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Main reasoning model. Examples: gpt-5.5, gpt-4o, gpt-4-turbo.
# Must be a model your OpenAI account has access to.
OPENAI_MODEL=gpt-5.5

# Smaller/cheaper model for validation and utility tasks.
# Examples: gpt-5.5-mini, gpt-4o-mini.
OPENAI_MODEL_MINI=gpt-5.5-mini

# ── Authentication (web demo only — leave defaults for self-host) ─────────────
# AUTH_MODE=disabled: no login flow, anyone can create sessions (self-host default).
# AUTH_MODE=required: magic-link email login + "1 session per email" gate.
#                     Set this only when deploying the public web demo.
# AUTH_MODE=disabled

# Resend (https://resend.com) — used only when AUTH_MODE=required.
# Get an API key from your Resend dashboard. The "from" address must be
# verified in Resend; if you have no verified domain, use onboarding@resend.dev
# (note: this address only delivers mail to your Resend-account owner email).
# RESEND_API_KEY=re_...
# RESEND_FROM=Research Agent <noreply@your-domain.com>

# Public URLs used in magic-link emails and redirects. Required when AUTH_MODE=required.
# BACKEND_PUBLIC_URL=https://api.yourdomain.com
# FRONTEND_URL=https://yourdomain.com

# ── Optional overrides ────────────────────────────────────────────────────────
# These are pre-configured in docker-compose.yml; uncomment only to override.
#
# CORS_ORIGINS=http://localhost:3001
# DATABASE_URL=sqlite+aiosqlite:////data/research_agent.db
# CHROMA_PERSIST_DIR=/data/chroma_db
# UPLOAD_DIR=/data/uploads
# OUTPUT_DIR=/data/outputs
